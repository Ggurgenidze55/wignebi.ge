generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccessTier {
  FREE
  SUBSCRIPTION
  PREMIUM
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Author {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  bio          String   @db.Text
  imageUrl     String?
  relatedSlugs String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  books Book[]
}

model Genre {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  nameEn       String
  description  String   @db.Text
  relatedSlugs String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  books BookGenre[]
}

model Book {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  titleEn     String?
  description String     @db.Text
  narrator    String
  coverHue    Int        @default(200)
  coverUrl    String?
  rating      Float?
  access      AccessTier @default(FREE)
  priceGel    Int?
  durationSec Int        @default(0)
  tags        String[]   @default([])
  publishedAt DateTime
  popularity  Int        @default(0)
  isNew       Boolean    @default(false)
  published   Boolean    @default(true)
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author   Author      @relation(fields: [authorId], references: [id])
  genres   BookGenre[]
  chapters Chapter[]
}

model BookGenre {
  bookId  String
  genreId String
  book    Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([bookId, genreId])
}

model Chapter {
  id             String   @id @default(cuid())
  bookId         String
  title          String
  orderIndex     Int
  durationSec    Int      @default(0)
  audioUrl       String?
  readingParagraphs String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, orderIndex])
  @@index([bookId])
}
