# PostgreSQL (Railway)
DATABASE_URL="postgresql://user:pass@host:5432/tsignebi?sslmode=require"

# NestJS CMS API
PORT=4000
NODE_ENV=development
JWT_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
BFF_SECRET="change-me-bff"
CORS_ORIGIN="http://localhost:3000"
ADMIN_EMAIL="admin@tsignebi.ge"
ADMIN_PASSWORD="change-me"

# Next.js
CMS_API_URL="http://localhost:4000/api"
CMS_REVALIDATE=60

# Cloudflare R2
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="tsignebi-media"
R2_PUBLIC_URL="https://media.tsignebi.ge"
