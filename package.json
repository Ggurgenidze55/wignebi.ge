{
  "name": "tsignebi",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "node scripts/dev.mjs",
    "dev:api": "npm run dev -w @tsignebi/api",
    "build": "npm run build -w @tsignebi/api && npm run build:web",
    "build:web": "next build",
    "start": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "start:web": "next start -p 3000",
    "start:api": "npm run start:prod -w @tsignebi/api",
    "db:generate": "npm run db:generate -w @tsignebi/database",
    "db:push": "npm run db:push -w @tsignebi/database",
    "db:migrate": "npm run db:migrate -w @tsignebi/database",
    "db:seed": "npm run db:seed -w @tsignebi/database",
    "postinstall": "npm run db:generate -w @tsignebi/database",
    "lint": "next lint"
  }
}
